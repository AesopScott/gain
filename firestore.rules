rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function memberDoc(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/members/$(uid()));
    }
    function isMember(companyId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/companies/$(companyId)/members/$(uid()));
    }
    function memberRole(companyId) {
      return memberDoc(companyId).data.role;
    }
    function isOwner(companyId) {
      return isMember(companyId) && memberRole(companyId) == 'owner';
    }
    function isAdmin(companyId) {
      return isMember(companyId) && memberRole(companyId) in ['owner', 'admin'];
    }
    function isEditor(companyId) {
      return isMember(companyId) && memberRole(companyId) in ['owner', 'admin', 'editor'];
    }

    // Platform-wide super admin. Only one identity, enforced by email match.
    // The actual Auth user must be created in the Firebase Console.
    function isSuperadmin() {
      return isSignedIn() && request.auth.token.email == 'admin@governainow.com';
    }

    // ---------- user profiles ----------
    // Each authenticated user has a /users/{uid} doc with their display name and
    // list of companies they belong to. A user may only read or write their own.
    match /users/{userId} {
      allow read: if isSignedIn() && uid() == userId;
      allow create: if isSignedIn() && uid() == userId;
      // Users can update their own profile, but deletion-control fields
      // (deletionStatus, deletionRequestedAt, scheduledHardDeleteAt,
      // deletionCertificateId) may only be written by Cloud Functions via
      // the Admin SDK — never by a client. Prevents a user from cancelling
      // or re-scheduling their own deletion sweep.
      allow update: if isSignedIn() && uid() == userId &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['deletionStatus', 'deletionRequestedAt', 'scheduledHardDeleteAt', 'deletionCertificateId']);
      allow delete: if false;
    }

    // ---------- companies ----------
    // A company document contains shared metadata (name, owner, created date).
    // Members are a subcollection; the member doc's presence is the gate for
    // access to all nested collections.
    match /companies/{companyId} {
      // Anyone signed in can create a new company (they become owner in a
      // transactional client call that also creates their member doc).
      allow create: if isSignedIn() &&
        request.resource.data.ownerUid == uid();

      // Any signed-in user can read the company document (name, industry, size)
      // for company discovery / join requests. Subcollection rules remain member-only.
      allow read: if isSignedIn();

      // Only owners/admins can update top-level company fields — but billing
      // fields (planOverride, stripePlan, stripeCustomerId, stripeSubscriptionId)
      // may only be changed by the platform super admin. Deletion-control
      // fields (deletionStatus, deletionRequestedAt, deletionRequestedByUid,
      // scheduledHardDeleteAt, deletionCertificateId) are written by Cloud
      // Functions via the Admin SDK and must not be client-writable. This
      // prevents a company admin from self-granting a paid plan or
      // un-cancelling a scheduled deletion.
      allow update: if isAdmin(companyId) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['planOverride', 'stripePlan', 'stripeCustomerId', 'stripeSubscriptionId',
                   'deletionStatus', 'deletionRequestedAt', 'deletionRequestedByUid',
                   'scheduledHardDeleteAt', 'deletionCertificateId']);
      allow update: if isSuperadmin();

      // Only owner can delete (rarely used; usually soft-delete via archived flag)
      allow delete: if isOwner(companyId);

      // --- members subcollection ---
      // A member doc models role + email + joined date. Members can see each
      // other; admins can add/remove members; users can read their own member doc.
      match /members/{memberUid} {
        allow read: if isMember(companyId) || uid() == memberUid || isSuperadmin();
        // Three paths to create a member doc:
        //   (a) an existing admin adds someone,
        //   (b) the owner self-creates their owner record at company-creation time,
        //   (c) an invited user self-redeems by passing a matching inviteId.
        allow create: if
          isAdmin(companyId)
          // getAfter (not get) so the rule sees the company doc written in the
          // SAME transaction that creates this owner member record.
          || (isSignedIn() && uid() == memberUid &&
              getAfter(/databases/$(database)/documents/companies/$(companyId)).data.ownerUid == uid())
          || (isSignedIn() && uid() == memberUid &&
              request.resource.data.inviteId is string &&
              get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.email == request.auth.token.email &&
              get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.companyId == companyId &&
              get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.role == request.resource.data.role);
        allow update: if isAdmin(companyId);
        allow delete: if isAdmin(companyId) && memberUid != get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUid;
      }

      // --- framework posture ---
      match /frameworkPosture/{docId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow write: if isAdmin(companyId);
      }

      // --- use case intake ---
      match /intake/{useCaseId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- AI system inventory ---
      match /inventory/{systemId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- AI Impact Assessments ---
      match /aias/{aiaId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- join requests (company discovery / self-service access) ---
      // Any signed-in user may submit a request for their own uid.
      // The requester may read their own request to check status.
      // Only admins can approve / deny / delete.
      match /joinRequests/{requestId} {
        allow create: if isSignedIn() && request.resource.data.uid == uid();
        allow read:   if isSignedIn() && (resource.data.uid == uid() || isAdmin(companyId));
        allow update: if isAdmin(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- Compliance checklists (per-company completion state) ---
      match /checklists/{checklistKey} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- Governance team roster ---
      match /team/{memberId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- Risk register ---
      match /risks/{riskId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- AI settings (legacy BYO-key, admin-only) ---
      // New AI flows use the shared platform key via the generatePolicy
      // Cloud Function. This collection stays for backward compat only.
      match /aiSettings/{docId} {
        allow read, write: if isAdmin(companyId);
      }

      // --- AI usage counters (written by Cloud Functions only) ---
      // Per-day policy-gen counters at companies/{id}/aiUsage/YYYY-MM-DD.
      // admin.firestore() in Cloud Functions bypasses these rules; clients
      // can read (admin-only) but never write.
      match /aiUsage/{docId} {
        allow read:  if isAdmin(companyId) || isSuperadmin();
        allow write: if false;
      }

      // --- governance policies ---
      match /policies/{policyId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- incident response tracking (Miscellaneous) ---
      match /incidents/{incidentId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- vendor contracts & BAAs (Miscellaneous) ---
      match /contracts/{contractId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- training tracker (Miscellaneous) ---
      match /trainingRoster/{personId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }
      match /trainingCourses/{courseId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }
      match /trainingClasses/{classId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- consent records ---
      match /consentRecords/{recordId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create: if isEditor(companyId);
        allow update: if isAdmin(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- public disclosure tracker ---
      match /disclosures/{disclosureId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create, update: if isEditor(companyId);
        allow delete: if isAdmin(companyId);
      }

      // --- audit log ---
      // Append-only journal written by editors, readable by members, never updated or deleted
      match /audit/{eventId} {
        allow read: if isMember(companyId) || isSuperadmin();
        allow create: if isEditor(companyId) &&
          request.resource.data.actorUid == uid();
        allow update, delete: if false;
      }
    }

    // ---------- support tickets ----------
    match /supportTickets/{ticketId} {
      allow create: if isSignedIn() && request.resource.data.uid == uid();
      allow read: if isSignedIn() && (resource.data.uid == uid() || isSuperadmin());
      allow update, delete: if isSuperadmin();
    }

    // ---------- invites ----------
    // Sent by an admin with a target email. When a new user signs up with that
    // email, their client redeems the invite (creates a member doc, deletes invite).
    match /invites/{inviteId} {
      allow read: if isSignedIn() &&
        (request.auth.token.email == resource.data.email ||
         isAdmin(resource.data.companyId));
      allow create: if isSignedIn() &&
        isAdmin(request.resource.data.companyId) &&
        request.resource.data.inviterUid == uid();
      allow delete: if isSignedIn() &&
        (request.auth.token.email == resource.data.email ||
         isAdmin(resource.data.companyId));
      allow update: if false;
    }

    // ---------- deletion certificates ----------
    // Issued by Cloud Functions when a workspace or account is scheduled for
    // deletion, and finalized when the hard-delete sweep runs. Readable by
    // the requester, by members of the workspace (for workspace certs), and
    // by superadmin. Never writable from the client — only Cloud Functions
    // via the Admin SDK write these docs.
    match /deletionCertificates/{certId} {
      allow read: if isSignedIn() && (
        resource.data.requestedByUid == uid() ||
        (resource.data.entityType == 'workspace' && isMember(resource.data.entityId)) ||
        isSuperadmin()
      );
      allow write: if false;
    }

    // ---------- platform audit ----------
    // Platform-level audit log for account-scoped events (user deletions,
    // platform-wide admin actions). Written only by Cloud Functions; readable
    // by superadmin.
    match /platformAudit/{entryId} {
      allow read: if isSuperadmin();
      allow write: if false;
    }
  }
}
